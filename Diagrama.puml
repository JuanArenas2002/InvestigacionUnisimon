@startuml Diagrama
title Sistema de Integracion y Reconciliacion Bibliografica - Minciencias Colombia

left to right direction
skinparam componentStyle rectangle
skinparam shadowing false
skinparam backgroundColor #F8FAFC
skinparam defaultFontName Arial
skinparam ArrowColor #475569
skinparam ArrowThickness 1.8

skinparam package {
  BackgroundColor #FFFFFF
  BorderColor #CBD5E1
  FontStyle bold
  FontColor #0F172A
  FontSize 12
}

skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #94A3B8
  FontColor #0F172A
  FontSize 11
}

skinparam database {
  BackgroundColor #FFFBEB
  BorderColor #D97706
  FontColor #0F172A
  FontSize 10
}

' BLOQUE 1 - ENTRADA
package "ENTRADA" as P1 #EFF6FF {
  [Parametros\n----------\nORCID\nROR ID\nAfiliacion\nRango de anos] as Input
}

' BLOQUE 2 - PLUGIN ARCHITECTURE
package "FUENTES  |  Plugin Architecture" as P2 #EFF6FF {

  [SOURCE_REGISTRY\nauto-discovery\nsources/*.py\nSourceDefinition] as REG #E0E7FF

  [Scopus\nElsevier API] as S #DBEAFE
  [OpenAlex\nOpen API] as O #DBEAFE
  [Web of Science\nClarivate API] as W #DBEAFE
  [CvLAC\nScienti] as C #DCFCE7
  [Datos Abiertos\ndatos.gov.co] as DA #DCFCE7
  [GrupLAC\nScienti grupos] as GL #DCFCE7

  [Nueva Fuente\nsources/nueva.py\nregistrar en\nSOURCE_REGISTRY] as NEW #F1F5F9

  S  -[#6366F1]-> REG : <<plugin>>
  O  -[#6366F1]-> REG : <<plugin>>
  W  -[#6366F1]-> REG : <<plugin>>
  C  -[#6366F1]-> REG : <<plugin>>
  DA -[#6366F1]-> REG : <<plugin>>
  GL -[#6366F1]-> REG : <<plugin>>
  NEW .[#94A3B8].> REG : <<plug and play>>
}

' BLOQUE 3 - ALMACENAMIENTO RAW
package "RAW  |  *_records" as P3 #FFFBEB {
  database "fuente_records\n--------------\n1 tabla por plugin\nauto-generada\ndesde el modelo" as DB_RAW
}

' BLOQUE 4 - MOTOR
package "MOTOR DE RECONCILIACION\nreconciliation/engine.py" as P4 #F0FDF4 {
  [1. Deduplicacion\nSHA-256 dedup_hash] as D
  [2. Normalizacion\ntitulo - autores - idioma] as N
  [3. Matching\nDOI - titulo - fuzzy] as M
  [4. Enriquecimiento\nfirst-source-wins\nfield_provenance JSONB] as E

  D -[#16A34A]-> N
  N -[#16A34A]-> M
  M -[#16A34A]-> E
}

' BLOQUE 5 - BASE CANONICA
package "BASE CANONICA  |  PostgreSQL" as P5 #F5F3FF {
  database "canonical_publications\n--------------------\ntitle - doi - abstract\nkeywords - publisher\nfirst_author - cine_code\nknowledge_area - pesos\n\nauthors\n--------------------\nexternal_ids JSONB" as DB_CANON
}

' BLOQUE 6 - SALIDA
package "SALIDA" as P6 #FDF4FF {
  [API REST\nFastAPI] as API
  [Reportes\nde Calidad] as REP
}

' FLUJO PRINCIPAL
Input -[#3B82F6]-> S
Input -[#3B82F6]-> O
Input -[#3B82F6]-> W
Input -[#3B82F6]-> C
Input -[#3B82F6]-> DA
Input -[#3B82F6]-> GL

REG -[#F59E0B]-> DB_RAW : genera tabla\npor fuente

DB_RAW -[#6366F1]-> D

E -[#8B5CF6]-> DB_CANON

DB_CANON -[#EC4899]-> API
DB_CANON -[#EC4899]-> REP

note bottom of NEW
  Agregar una fuente:
  1. Crear sources/nueva.py
  2. Definir modelo + builder
  3. Llamar SOURCE_REGISTRY.register()
  --------------------------------
  El resto del sistema lo detecta
  automaticamente al arrancar.
end note

@enduml
